let scores = JSON.parse(localStorage.getItem('md2_scores') || '{}');
let shownMilestones = new Set(JSON.parse(localStorage.getItem('md2_shown') || '[]'));

let displayBills = totalBills;
let targetBills = totalBills;

const canvas = document.getElementById('scene');
const ctx = canvas.getContext('2d');
let W, H;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

function getSkyColor(altM) {
  let lo = MILESTONES[0], hi = MILESTONES[MILESTONES.length - 1];
  for (let i = 0; i < MILESTONES.length - 1; i++) {
    if (altM >= MILESTONES[i].m && altM < MILESTONES[i + 1].m) {
      lo = MILESTONES[i]; hi = MILESTONES[i + 1]; break;
    }
  }
  const t = lo.m === hi.m ? 0 : Math.min(1, (altM - lo.m) / (hi.m - lo.m));
  const r = Math.round(lo.sky[0] + (hi.sky[0] - lo.sky[0]) * t);
  const g = Math.round(lo.sky[1] + (hi.sky[1] - lo.sky[1]) * t);
  const b = Math.round(lo.sky[2] + (hi.sky[2] - lo.sky[2]) * t);
  return [r, g, b];
}

// Nieuwe verbeterde geldstapel
function drawMoneyStack(bills) {
  if (bills <= 0) return;
  const maxPixH = H * 0.52;
  let stackPixH = bills;
  if (stackPixH > maxPixH) stackPixH = maxPixH;

  const cx = W / 2;
  const by = H * 0.72;
  const sw = 145;
  const depth = 26;
  const top = by - stackPixH;

  ctx.save();

  // Voorkant
  const frontGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2, by);
  frontGrad.addColorStop(0, '#22c55e');
  frontGrad.addColorStop(0.4, '#34d46b');
  frontGrad.addColorStop(1, '#15803d');
  ctx.fillStyle = frontGrad;
  ctx.fillRect(cx - sw/2, top, sw, stackPixH);

  // Biljetlijnen
  ctx.strokeStyle = 'rgba(10,50,20,0.6)';
  for (let i = 0; i < 180; i++) {
    const y = top + (stackPixH / 180) * i;
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 8, y);
    ctx.lineTo(cx + sw/2 - 8, y);
    ctx.stroke();
  }

  // Bovenkant
  ctx.fillStyle = '#4ade80';
  ctx.beginPath();
  ctx.moveTo(cx - sw/2, top);
  ctx.lineTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.45);
  ctx.lineTo(cx - sw/2 + depth, top - depth*0.45);
  ctx.closePath();
  ctx.fill();

  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = 'bold 36px DM Mono';
  ctx.textAlign = 'center';
  ctx.fillText('💵', cx, top + stackPixH * 0.5);

  ctx.restore();
}

function loop() {
  requestAnimationFrame(loop);
  const altM = displayBills * BILL_M;
  const [r, g, b] = getSkyColor(altM);

  ctx.fillStyle = `rgb(${r},${g},${b})`;
  ctx.fillRect(0, 0, W, H);

  drawMoneyStack(displayBills);
}

document.getElementById('click-btn').addEventListener('click', () => {
  totalBills++;
  displayBills = targetBills = totalBills;
  localStorage.setItem('md2_bills', totalBills);
});

loop();
