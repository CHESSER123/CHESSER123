<body>

<canvas id="scene"></canvas>

<div id="hud-left">
  <div id="hud-alt">0,0000</div>
  <div id="hud-unit">meter</div>
</div>

<div id="bill-counter">
  <div id="bill-number">0</div>
  <div id="bill-label">biljetten gestapeld</div>
</div>

<button id="click-btn">💵</button>

<script>
const BILL_M = 0.0001;
let totalBills = parseInt(localStorage.getItem('md_bills') || '0');
let displayBills = totalBills;
let targetBills = totalBills;

const canvas = document.getElementById('scene');
const ctx = canvas.getContext('2d');
let W, H;

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

function getSkyColor(alt) {
  if (alt < 1000) return [100, 180, 240];
  if (alt < 10000) return [60, 140, 200];
  return [20, 60, 120];
}

function drawGround(alt) {
  const gy = H * 0.73;
  const a = Math.max(0.1, 1 - alt / 5000);
  ctx.globalAlpha = a;
  const grad = ctx.createLinearGradient(0, gy, 0, H);
  grad.addColorStop(0, '#2a2a2a');
  grad.addColorStop(1, '#1a1a1a');
  ctx.fillStyle = grad;
  ctx.fillRect(0, gy, W, H - gy);
  ctx.globalAlpha = 1;
}

function drawMoneyStack(bills) {
  if (bills <= 0) return;
  const maxH = H * 0.55;
  let h = Math.min(bills * 1.6, maxH);
  const cx = W / 2;
  const baseY = H * 0.73;
  const sw = 148;
  const depth = 28;
  const top = baseY - h;

  ctx.save();

  // Rechter zijkant (donker)
  ctx.fillStyle = '#145a24';
  ctx.beginPath();
  ctx.moveTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.5);
  ctx.lineTo(cx + sw/2 + depth, baseY - depth*0.5);
  ctx.lineTo(cx + sw/2, baseY);
  ctx.fill();

  // Voorkant (mooie gradient)
  const grad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2, baseY);
  grad.addColorStop(0, '#22c55e');
  grad.addColorStop(0.45, '#4ade80');
  grad.addColorStop(1, '#15803d');
  ctx.fillStyle = grad;
  ctx.fillRect(cx - sw/2, top, sw, h);

  // Biljet lijnen
  ctx.strokeStyle = 'rgba(0,40,15,0.6)';
  ctx.lineWidth = 2;
  for (let i = 0; i < 140; i++) {
    const y = top + (h / 140) * i;
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 10, y);
    ctx.lineTo(cx + sw/2 - 10, y);
    ctx.stroke();
  }

  // Bovenkant (volgt mooi de zijkant)
  ctx.fillStyle = '#86efac';
  ctx.beginPath();
  ctx.moveTo(cx - sw/2, top);
  ctx.lineTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.48);
  ctx.lineTo(cx - sw/2 + depth, top - depth*0.48);
  ctx.closePath();
  ctx.fill();

  // 💵 symbool groot op de stapel
  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.font = 'bold 46px sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('💵', cx, top + h * 0.48);

  ctx.restore();
}

// Eenvoudige voorwerpen / dieren (verschijnen naarmate je hoger komt)
function drawObjects(alt) {
  const gy = H * 0.73;

  if (alt < 50) {
    // Boom
    ctx.fillStyle = '#166534';
    ctx.fillRect(W*0.25, gy - 120, 35, 120);
    ctx.fillStyle = '#4ade80';
    ctx.beginPath(); ctx.arc(W*0.27, gy - 140, 55, 0, Math.PI*2); ctx.fill();
  }

  if (alt > 30 && alt < 300) {
    // Giraffe
    ctx.fillStyle = '#facc15';
    ctx.fillRect(W*0.72, gy - 180, 28, 180);           // nek + lijf
    ctx.fillRect(W*0.68, gy - 210, 40, 45);            // hoofd
    ctx.fillStyle = '#854d0e';
    ctx.fillRect(W*0.73, gy - 40, 22, 40);             // poten
  }

  if (alt > 100) {
    // Huis
    ctx.fillStyle = '#b91c1c';
    ctx.beginPath();
    ctx.moveTo(W*0.12, gy - 90);
    ctx.lineTo(W*0.22, gy - 140);
    ctx.lineTo(W*0.32, gy - 90);
    ctx.fill();
    ctx.fillStyle = '#1e40af';
    ctx.fillRect(W*0.15, gy - 90, 40, 45);
  }
}

document.getElementById('click-btn').addEventListener('click', () => {
  totalBills += 15000;
  targetBills = totalBills;
  localStorage.setItem('md_bills', totalBills);
});

function loop() {
  requestAnimationFrame(loop);
  displayBills += (targetBills - displayBills) * 0.1;

  const altM = displayBills * BILL_M;
  const [r,g,b] = getSkyColor(altM);

  ctx.fillStyle = `rgb(${r},${g},${b})`;
  ctx.fillRect(0, 0, W, H);

  drawGround(altM);
  drawObjects(altM);
  drawMoneyStack(displayBills);

  // Tellers updaten
  const altEl = document.getElementById('hud-alt');
  const unitEl = document.getElementById('hud-unit');
  if (altM >= 1000) {
    altEl.textContent = (altM / 1000).toFixed(4);
    unitEl.textContent = 'kilometer';
  } else {
    altEl.textContent = altM.toFixed(4);
    unitEl.textContent = 'meter';
  }

  document.getElementById('bill-number').textContent = Math.floor(totalBills).toLocaleString('nl-NL');
}
loop();
</script>
