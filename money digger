  grad.addColorStop(0, '#323232');
  grad.addColorStop(1, '#1c1c1c');
  ctx.fillStyle = grad;
  ctx.fillRect(0, gy, W, H - gy);
}

function drawMoneyStack(bills) {
  if (bills <= 0) return;
  const maxPixH = H * 0.52;
  let stackPixH = bills;
  if (stackPixH > maxPixH) stackPixH = maxPixH;

  const cx = W / 2;
  const by = H * 0.72;
  const sw = 145;
  const depth = 26;
  const top = by - stackPixH;

  ctx.save();

  // Voorkant
  const frontGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2, by);
  frontGrad.addColorStop(0, '#22c55e');
  frontGrad.addColorStop(0.4, '#34d46b');
  frontGrad.addColorStop(1, '#15803d');
  ctx.fillStyle = frontGrad;
  ctx.fillRect(cx - sw/2, top, sw, stackPixH);

  // Biljetlijnen
  ctx.strokeStyle = 'rgba(10,50,20,0.65)';
  ctx.lineWidth = 1.5;
  const lines = Math.min(220, Math.floor(stackPixH / 1.8));
  for (let i = 0; i < lines; i++) {
    const y = top + (stackPixH / lines) * i;
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 8, y);
    ctx.lineTo(cx + sw/2 - 8, y);
    ctx.stroke();
  }

  // Bovenkant (3D)
  const topGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2 + depth, top - depth*0.45);
  topGrad.addColorStop(0, '#4ade80');
  topGrad.addColorStop(1, '#34c16a');
  ctx.fillStyle = topGrad;
  ctx.beginPath();
  ctx.moveTo(cx - sw/2, top);
  ctx.lineTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.45);
  ctx.lineTo(cx - sw/2 + depth, top - depth*0.45);
  ctx.closePath();
  ctx.fill();

  // Symbool
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = `bold ${Math.min(48, stackPixH*0.25)}px DM Mono`;
  ctx.textAlign = 'center';
  ctx.fillText('💵', cx, top + stackPixH * 0.5);

  ctx.restore();
}

document.getElementById('click-btn').addEventListener('click', () => {
  totalBills += 10000;
  targetBills = totalBills;
  localStorage.setItem('md2_bills', totalBills);
});

function loop() {
  requestAnimationFrame(loop);
  displayBills += (targetBills - displayBills) * 0.12;

  const altM = displayBills * BILL_M;
  const [r,g,b] = getSkyColor(altM);

  ctx.fillStyle = `rgb(${r},${g},${b})`;
  ctx.fillRect(0, 0, W, H);

  drawGround();
  drawMoneyStack(displayBills);

  // HUD update
  const altEl = document.getElementById('hud-alt');
  const unitEl = document.getElementById('hud-unit');
  if (altM >= 1000) {
    altEl.textContent = (altM/1000).toFixed(4);
    unitEl.textContent = 'kilometer';
  } else {
    altEl.textContent = altM.toFixed(4);
    unitEl.textContent = 'meter';
  }
  document.getElementById('bill-number').textContent = totalBills.toLocaleString('nl-NL');
}
loop();
