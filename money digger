  { m: 828,         label: 'Burj Khalifa',            emoji: '🏙️', sky: [60, 130, 190] },
  { m: 1000,        label: '1 kilometer hoog!',       emoji: '🎉', sky: [50, 120, 180] },
  { m: 2000,        label: 'Laagste wolken',          emoji: '☁️', sky: [40, 100, 165] },
  { m: 8849,        label: 'Top van de Everest',      emoji: '🏔️', sky: [25, 75, 140] },
  { m: 10000,       label: 'Kruisshoogte vliegtuig',  emoji: '✈️', sky: [15, 55, 115] },
  { m: 36000,       label: 'Straalstroom',            emoji: '💨', sky: [8, 30, 80]  },
  { m: 100000,      label: 'Kármánlijn — ruimte!',    emoji: '🚀', sky: [2, 5, 20]   },
  { m: 408000,      label: 'Internationaal Ruimtestation', emoji: '🛸', sky: [1, 2, 8] },
  { m: 384400000,   label: 'Afstand tot de Maan',     emoji: '🌕', sky: [0, 0, 5]    },
  { m: 149600000000,label: 'Afstand tot de Zon',      emoji: '☀️', sky: [0, 0, 2]    },
];

// Visual elements at certain altitudes
const ELEMENTS = [
  { m: 0,      draw: drawGround    },
  { m: 0,      draw: drawBuildings },
  { m: 2000,   draw: drawClouds    },
  { m: 8849,   draw: drawEverest   },
  { m: 36000,  draw: drawJetstream },
  { m: 100000, draw: drawSpaceEdge },
  { m: 408000, draw: drawISS       },
];

// ═══════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════
let totalBills = parseInt(localStorage.getItem('md2_bills') || '0');
let myClicks   = parseInt(localStorage.getItem('md2_myclicks') || '0');
let myName     = localStorage.getItem('md2_name') || 'Speler' + Math.floor(Math.random()*9999);
let scores     = JSON.parse(localStorage.getItem('md2_scores') || '{}');
let shownMilestones = new Set(JSON.parse(localStorage.getItem('md2_shown') || '[]'));

// Smooth scroll
let displayBills = totalBills;
let targetBills  = totalBills;

// ═══════════════════════════════════════════════════
//  CANVAS
// ═══════════════════════════════════════════════════
const canvas = document.getElementById('scene');
const ctx    = canvas.getContext('2d');
let W, H;

function resize() {
  W = canvas.width  = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ═══════════════════════════════════════════════════
//  SKY COLOR
// ═══════════════════════════════════════════════════
function getSkyColor(altM) {
  let lo = MILESTONES[0], hi = MILESTONES[MILESTONES.length - 1];
  for(let i = 0; i < MILESTONES.length - 1; i++) {
    if(altM >= MILESTONES[i].m && altM < MILESTONES[i+1].m) {
      lo = MILESTONES[i]; hi = MILESTONES[i+1]; break;
    }
  }
  const t = lo.m === hi.m ? 0 : Math.min(1, (altM - lo.m) / (hi.m - lo.m));
  const r = Math.round(lo.sky[0] + (hi.sky[0] - lo.sky[0]) * t);
  const g = Math.round(lo.sky[1] + (hi.sky[1] - lo.sky[1]) * t);
  const b = Math.round(lo.sky[2] + (hi.sky[2] - lo.sky[2]) * t);
  return [r, g, b];
}

// ═══════════════════════════════════════════════════
//  DRAW HELPERS (scene elements)
// ═══════════════════════════════════════════════════
let cloudT = 0;
let starField = [];
for(let i = 0; i < 300; i++) {
  starField.push({ x: Math.random(), y: Math.random(), r: 0.4 + Math.random()*1.2, b: Math.random() });
}

function sceneAlpha(altM, startM, endM) {
  if(altM < startM) return 0;
  if(altM > endM) return 0;
  const mid = (startM + endM) / 2;
  if(altM < mid) return Math.min(1, (altM - startM) / (mid - startM));
  return Math.min(1, (endM - altM) / (endM - mid));
}

function fadeIn(altM, startM, duration = startM * 0.5) {
  return Math.min(1, Math.max(0, (altM - startM) / duration));
}

// ── NIEUWE REALISTISCHE ASFALT GROND (prioriteit: mooier en gedetailleerder contact met geld) ──
function drawGround(altM) {
  const a = Math.max(0, 1 - altM / 3000);
  if(a <= 0) return;
  ctx.save();
  ctx.globalAlpha = a;

  const gy = H * 0.72;
  const cx = W / 2;

  // Realistische asfaltvloer (donker, textuur, perspectief)
  const grad = ctx.createLinearGradient(0, gy, 0, H);
  grad.addColorStop(0, '#323232');
  grad.addColorStop(1, '#1c1c1c');
  ctx.fillStyle = grad;
  ctx.fillRect(0, gy, W, H - gy);

  // Asfalt-textuur (fijne korrel + scheuren)
  ctx.strokeStyle = 'rgba(45,45,45,0.85)';
  ctx.lineWidth = 2;
  for(let i = 0; i < 80; i++) {
    const y = gy + (H - gy) * (i / 80);
    const offset = Math.sin(i * 0.2) * 8;
    ctx.beginPath();
    ctx.moveTo(0, y + offset);
    ctx.lineTo(W, y + offset * 0.5);
    ctx.stroke();
  }

  // Perspectief wegmarkeringen (centraal streep + randen)
  ctx.strokeStyle = 'rgba(220,220,220,0.9)';
  ctx.lineWidth = 7;
  ctx.setLineDash([35, 70]);
  ctx.beginPath();
  ctx.moveTo(cx - 4, gy);
  ctx.lineTo(cx - 4, H);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(cx + 4, gy);
  ctx.lineTo(cx + 4, H);
  ctx.stroke();
  ctx.setLineDash([]);

  ctx.strokeStyle = 'rgba(200,200,200,0.6)';
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.moveTo(cx - 65, gy);
  ctx.lineTo(W * 0.05, H);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(cx + 65, gy);
  ctx.lineTo(W * 0.95, H);
  ctx.stroke();

  // Scheuren voor extra realisme (rond de stapel)
  ctx.strokeStyle = 'rgba(60,60,60,0.6)';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(cx - 120, gy + 30);
  ctx.quadraticCurveTo(cx - 150, gy + 120, cx - 70, gy + 220);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(cx + 110, gy + 45);
  ctx.quadraticCurveTo(cx + 160, gy + 110, cx + 80, gy + 250);
  ctx.stroke();

  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(cx - 40, gy + 8);
  ctx.lineTo(cx - 55, gy + 45);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(cx + 35, gy + 12);
  ctx.lineTo(cx + 55, gy + 38);
  ctx.stroke();

  ctx.restore();
}

function drawBuildings(altM) {
  const a = Math.max(0, 1 - altM / 5000);
  if(a <= 0) return;
  ctx.save();
  ctx.globalAlpha = a;

  const gy = H * 0.72;
  const buildings = [
    { xf: 0.08, wf: 0.06, hf: 0.18, c: '#4a5568', windows: true },
    { xf: 0.15, wf: 0.09, hf: 0.26, c: '#2d3748', windows: true },
    { xf: 0.05, wf: 0.05, hf: 0.13, c: '#553a2a', windows: false },
    { xf: 0.78, wf: 0.08, hf: 0.22, c: '#4a5568', windows: true },
    { xf: 0.88, wf: 0.07, hf: 0.30, c: '#2d3748', windows: true },
    { xf: 0.94, wf: 0.05, hf: 0.14, c: '#553a2a', windows: false },
  ];

  for(const b of buildings) {
    const bx = W * b.xf;
    const bw = W * b.wf;
    const bh = H * b.hf;
    const by = gy - bh;

    ctx.fillStyle = shadeColor(b.c, -20);
    ctx.beginPath();
    ctx.moveTo(bx + bw, by);
    ctx.lineTo(bx + bw + 8, by - 6);
    ctx.lineTo(bx + bw + 8, gy - 6);
    ctx.lineTo(bx + bw, gy);
    ctx.fill();

    ctx.fillStyle = shadeColor(b.c, 30);
    ctx.beginPath();
    ctx.moveTo(bx, by);
    ctx.lineTo(bx + bw, by);
    ctx.lineTo(bx + bw + 8, by - 6);
    ctx.lineTo(bx + 8, by - 6);
    ctx.fill();

    ctx.fillStyle = b.c;
    ctx.fillRect(bx, by, bw, bh);

    if(b.windows) {
      for(let wy = by + 6; wy < gy - 4; wy += 10) {
        for(let wx = bx + 4; wx < bx + bw - 4; wx += 8) {
          const lit = Math.sin(wx * 0.7 + wy * 0.3) > 0;
          ctx.fillStyle = lit ? 'rgba(255,240,120,0.7)' : 'rgba(50,60,80,0.8)';
          ctx.fillRect(wx, wy, 4, 5);
        }
      }
    }
  }

  ctx.restore();
}

function drawClouds(altM) {
  const a = Math.min(
    Math.max(0, (altM - 1500) / 500),
    Math.max(0, 1 - (altM - 10000) / 2000)
  );
  if(a <= 0) return;
  ctx.save();
  ctx.globalAlpha = a * 0.9;
  cloudT += 0.001;

  const cloudDefs = [
    { xf: 0.1,  yf: 0.25, s: 70 },
    { xf: 0.35, yf: 0.38, s: 90 },
    { xf: 0.60, yf: 0.20, s: 60 },
    { xf: 0.80, yf: 0.33, s: 75 },
    { xf: 0.55, yf: 0.45, s: 55 },
  ];

  for(const c of cloudDefs) {
    const cx = ((c.xf + cloudT * 0.03) % 1.1) * W;
    const cy = c.yf * H;
    drawCloud3D(cx, cy, c.s);
  }
  ctx.restore();
}

function drawCloud3D(cx, cy, s) {
  ctx.fillStyle = 'rgba(180,190,210,0.6)';
  ctx.beginPath();
  ctx.ellipse(cx, cy + s*0.15, s*0.7, s*0.18, 0, 0, Math.PI*2);
  ctx.fill();

  ctx.fillStyle = 'rgba(255,255,255,0.95)';
  ctx.beginPath();
  ctx.arc(cx,       cy,       s*0.35, 0, Math.PI*2);
  ctx.arc(cx+s*0.3, cy-s*0.1, s*0.28, 0, Math.PI*2);
  ctx.arc(cx-s*0.3, cy+s*0.05,s*0.22, 0, Math.PI*2);
  ctx.arc(cx+s*0.1, cy-s*0.22,s*0.20, 0, Math.PI*2);
  ctx.fill();
}

function drawEverest(altM) { /* ongewijzigd */ const a = sceneAlpha(altM, 5000, 15000); if(a <= 0) return; ctx.save(); ctx.globalAlpha = a; ctx.fillStyle = '#7a8fa6'; ctx.beginPath(); ctx.moveTo(0, H); ctx.lineTo(W*0.2, H*0.55); ctx.lineTo(W*0.35, H*0.3); ctx.lineTo(W*0.5, H*0.48); ctx.lineTo(W*0.7, H*0.42); ctx.lineTo(W, H*0.58); ctx.lineTo(W, H); ctx.fill(); ctx.fillStyle = 'rgba(240,248,255,0.9)'; ctx.beginPath(); ctx.moveTo(W*0.28, H*0.38); ctx.lineTo(W*0.35, H*0.3); ctx.lineTo(W*0.42, H*0.38); ctx.fill(); ctx.fillStyle = 'rgba(240,248,255,0.7)'; ctx.beginPath(); ctx.moveTo(W*0.63, H*0.48); ctx.lineTo(W*0.7, H*0.42); ctx.lineTo(W*0.77, H*0.48); ctx.fill(); ctx.restore(); }

function drawJetstream(altM) { /* ongewijzigd */ const a = sceneAlpha(altM, 25000, 50000); if(a <= 0) return; ctx.save(); ctx.globalAlpha = a * 0.5; for(let i = 0; i < 5; i++) { const y = H * (0.2 + i * 0.15); const grad = ctx.createLinearGradient(0, y, W, y); grad.addColorStop(0, 'rgba(255,255,255,0)'); grad.addColorStop(0.3, 'rgba(255,255,255,0.6)'); grad.addColorStop(0.7, 'rgba(255,255,255,0.4)'); grad.addColorStop(1, 'rgba(255,255,255,0)'); ctx.strokeStyle = grad; ctx.lineWidth = 1.5 + i * 0.5; ctx.beginPath(); ctx.moveTo(0, y + Math.sin(i) * 8); ctx.bezierCurveTo(W*0.3, y - 10, W*0.7, y + 10, W, y + Math.cos(i)*5); ctx.stroke(); } ctx.restore(); }

