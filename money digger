window.addEventListener('resize', resize);

function drawMoneyStack(bills) {
    if (bills <= 0) return;
    
    const maxH = canvas.height * 0.58;
    let h = Math.min(bills * 1.8, maxH);
    const cx = canvas.width / 2;
    const baseY = canvas.height * 0.78;
    
    // Schaduw
    ctx.shadowColor = "black";
    ctx.shadowBlur = 40;
    ctx.shadowOffsetY = 25;
    ctx.fillStyle = "rgba(0,0,0,0.5)";
    ctx.fillRect(cx - 85, baseY, 170, 25);
    ctx.shadowBlur = 0;
    ctx.shadowOffsetY = 0;
    
