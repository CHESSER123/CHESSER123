#hud-left { position: fixed; top: 24px; left: 28px; z-index: 20; pointer-events: none; }
#hud-alt { font-size: 2.6rem; font-weight: 700; color: #fff; line-height: 1; text-shadow: 0 2px 20px rgba(0,0,0,0.5); }
#hud-unit { font-size: 1rem; font-weight: 300; color: rgba(255,255,255,0.7); margin-top: 2px; }

