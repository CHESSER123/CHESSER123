    grad.addColorStop(0, "#22c55e");
    grad.addColorStop(0.5, "#34d46b");
    grad.addColorStop(1, "#15803d");
    ctx.fillStyle = grad;
    ctx.fillRect(cx - 80, baseY - h, 160, h);
    
    // Biljet lijnen (papier effect)
    ctx.strokeStyle = "rgba(255,255,255,0.25)";
    ctx.lineWidth = 2;
    for (let i = 18; i < h; i += 18) {
        ctx.beginPath();
        ctx.moveTo(cx - 72, baseY - i);
        ctx.lineTo(cx + 72, baseY - i);
        ctx.stroke();
    }
    
    // Bovenkant van de stapel (3D effect)
    ctx.fillStyle = "#4ade80";
    ctx.beginPath();
    ctx.moveTo(cx - 80, baseY - h);
    ctx.lineTo(cx + 80, baseY - h);
    ctx.lineTo(cx + 92, baseY - h - 22);
    ctx.lineTo(cx - 68, baseY - h - 22);
    ctx.closePath();
    ctx.fill();
    
    // 💵 symbool
    ctx.fillStyle = "rgba(255,255,255,0.35)";
    ctx.font = "bold 52px sans-serif";
    ctx.textAlign = "center";
    ctx.fillText("💵", cx, baseY - h/2 + 10);
}

