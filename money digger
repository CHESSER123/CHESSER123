function getSkyColor(altM) {
  let lo = MILESTONES[0], hi = MILESTONES[MILESTONES.length-1];
  for(let i = 0; i < MILESTONES.length-1; i++) {
    if(altM >= MILESTONES[i].m && altM < MILESTONES[i+1].m) {
      lo = MILESTONES[i]; hi = MILESTONES[i+1]; break;
    }
  }
  const t = lo.m === hi.m ? 0 : Math.min(1, (altM - lo.m) / (hi.m - lo.m));
  const r = Math.round(lo.sky[0] + (hi.sky[0] - lo.sky[0]) * t);
  const g = Math.round(lo.sky[1] + (hi.sky[1] - lo.sky[1]) * t);
  const b = Math.round(lo.sky[2] + (hi.sky[2] - lo.sky[2]) * t);
  return [r, g, b];
}

