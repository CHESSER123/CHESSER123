<script>
// ═══════════════════════════════════════════════════
//  CONSTANTS & MILESTONES
// ═══════════════════════════════════════════════════
const BILL_M = 0.0001; // 0.1mm per biljet

const MILESTONES = [
  { m: 0,           label: 'Grond',                  emoji: '🌱', sky: [135, 206, 235] },
  { m: 1,           label: '10.000 biljetten — 1 meter!', emoji: '📏', sky: [135, 206, 235] },
