function drawMoneyStack(bills) {
  if (bills <= 0) return;
  
  const maxH = H * 0.56;
  let stackH = Math.min(bills * 1.4, maxH);   // 1 biljet = kleine hoogte
  const cx = W / 2;
  const baseY = H * 0.73;
  const width = 152;
  const depth = 29;
  const top = baseY - stackH;

  ctx.save();

  // Rechter zijkant (donker)
  const sideGrad = ctx.createLinearGradient(cx + width/2, top, cx + width/2 + depth, baseY);
  sideGrad.addColorStop(0, '#145a24');
  sideGrad.addColorStop(1, '#0f3f1a');
  ctx.fillStyle = sideGrad;
  ctx.beginPath();
  ctx.moveTo(cx + width/2, top);
  ctx.lineTo(cx + width/2 + depth, top - depth * 0.48);
  ctx.lineTo(cx + width/2 + depth, baseY - depth * 0.48);
  ctx.lineTo(cx + width/2, baseY);
  ctx.fill();

  // Voorkant geldstapel
  const frontGrad = ctx.createLinearGradient(cx - width/2, top, cx + width/2, baseY);
  frontGrad.addColorStop(0, '#22c55e');
  frontGrad.addColorStop(0.5, '#4ade80');
  frontGrad.addColorStop(1, '#15803d');
  ctx.fillStyle = frontGrad;
  ctx.fillRect(cx - width/2, top, width, stackH);

  // Gedetailleerde biljetlijnen
  ctx.strokeStyle = 'rgba(0, 45, 20, 0.75)';
  ctx.lineWidth = 1.8;
  for (let i = 0; i < 180; i++) {
    const y = top + (stackH / 180) * i + 4;
    ctx.beginPath();
    ctx.moveTo(cx - width/2 + 12, y);
    ctx.lineTo(cx + width/2 - 12, y);
    ctx.stroke();
