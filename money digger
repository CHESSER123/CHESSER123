function drawGround(altM) {
  const a = Math.max(0, 1 - altM / 3000);
  if(a <= 0) return;
  ctx.save();
  ctx.globalAlpha = a;
  const gy = H * 0.72;
  const cx = W / 2;

  const grad = ctx.createLinearGradient(0, gy, 0, H);
  grad.addColorStop(0, '#323232');
  grad.addColorStop(1, '#1c1c1c');
  ctx.fillStyle = grad;
  ctx.fillRect(0, gy, W, H - gy);

  ctx.strokeStyle = 'rgba(45,45,45,0.85)';
  ctx.lineWidth = 2;
  for(let i = 0; i < 80; i++) {
    const y = gy + (H - gy) * (i / 80);
    const offset = Math.sin(i * 0.2) * 8;
    ctx.beginPath();
    ctx.moveTo(0, y + offset);
    ctx.lineTo(W, y + offset * 0.5);
    ctx.stroke();
  }

  ctx.strokeStyle = 'rgba(220,220,220,0.9)';
  ctx.lineWidth = 7;
  ctx.setLineDash([35, 70]);
  ctx.beginPath(); ctx.moveTo(cx - 4, gy); ctx.lineTo(cx - 4, H); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(cx + 4, gy); ctx.lineTo(cx + 4, H); ctx.stroke();
  ctx.setLineDash([]);

  ctx.restore();
}

function drawMoneyStack(bills) {
  if(bills <= 0) return;

  const maxPixH = H * 0.52;
  let stackPixH = bills;
  let pixPerBill = 1;
  if(stackPixH > maxPixH) {
    pixPerBill = maxPixH / bills;
    stackPixH = maxPixH;
  }

  const cx = W / 2;
  const by = H * 0.72;
  const sw = 145;
  const depth = 26;
  const top = by - stackPixH;

  ctx.save();

  // Schaduw op grond
  ctx.shadowColor = '#000';
  ctx.shadowBlur = 30;
  ctx.shadowOffsetY = 18;
  ctx.fillStyle = 'rgba(0,0,0,0.35)';
  ctx.fillRect(cx - sw/2 - 8, by, sw + 16, 18);
  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;

  // Rechter zijvlak
  const sideGrad = ctx.createLinearGradient(cx + sw/2, top, cx + sw/2 + depth, by);
  sideGrad.addColorStop(0, '#145a24');
  sideGrad.addColorStop(1, '#0f3f1a');
  ctx.fillStyle = sideGrad;
  ctx.beginPath();
  ctx.moveTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth * 0.45);
  ctx.lineTo(cx + sw/2 + depth, by - depth * 0.45);
  ctx.lineTo(cx + sw/2, by);
  ctx.closePath();
  ctx.fill();

  // Voorkant
  const frontGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2, by);
  frontGrad.addColorStop(0, '#22c55e');
  frontGrad.addColorStop(0.25, '#34d46b');
  frontGrad.addColorStop(1, '#16a34a');
  ctx.fillStyle = frontGrad;
  ctx.fillRect(cx - sw/2, top, sw, stackPixH);

  // Biljet lijnen
  ctx.strokeStyle = 'rgba(10,50,20,0.65)';
  ctx.lineWidth = 1;
  const numLines = Math.min(220, Math.floor(stackPixH / 1.8));
  const step = stackPixH / numLines;
  for(let i = 0; i < numLines; i++) {
    const y = top + (i * step) + (step / 2);
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 6, y);
    ctx.lineTo(cx + sw/2 - 6, y);
    ctx.stroke();
  }

  // Bovenkant
  const topGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2 + depth, top - depth*0.45);
  topGrad.addColorStop(0, '#4ade80');
  topGrad.addColorStop(1, '#34c16a');
  ctx.fillStyle = topGrad;
  ctx.beginPath();
  ctx.moveTo(cx - sw/2, top);
  ctx.lineTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.45);
  ctx.lineTo(cx - sw/2 + depth, top - depth*0.45);
  ctx.closePath();
  ctx.fill();

  ctx.fillStyle = 'rgba(255,255,255,0.22)';
  ctx.font = `900 ${Math.min(42, stackPixH * 0.22)}px DM Mono`;
  ctx.textAlign = 'center';
  ctx.fillText('💵', cx, top + stackPixH * 0.48);

  ctx.restore();
}

