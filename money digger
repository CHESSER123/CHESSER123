  // Bovenkant (mooie 3D die de zijkant volgt)
  ctx.fillStyle = '#86efac';
  ctx.beginPath();
  ctx.moveTo(cx - width/2, top);
  ctx.lineTo(cx + width/2, top);
  ctx.lineTo(cx + width/2 + depth, top - depth * 0.48);
  ctx.lineTo(cx - width/2 + depth, top - depth * 0.48);
  ctx.closePath();
  ctx.fill();

  // Glans op bovenkant
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.fillRect(cx - width/2 + 15, top + 6, width - 30, 8);

  // Groot 💵 symbool
  ctx.fillStyle = 'rgba(255,255,255,0.28)';
  ctx.font = 'bold 52px sans-serif';
