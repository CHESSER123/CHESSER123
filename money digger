// ── NIEUWE ZEER GEDETAILLEERDE 3D GELDSTACK (neal.fun-stijl + perfecte schaal + bovenkant volgt biljetten) ──
function drawMoneyStack(bills) {
  if(bills <= 0) return;

  const maxPixH = H * 0.52; // iets meer ruimte voor detail
  let stackPixH = bills;
  let pixPerBill = 1;
  if(stackPixH > maxPixH) {
    pixPerBill = maxPixH / bills;
    stackPixH = maxPixH;
  }

  const cx = W / 2;
  const by = H * 0.72;
  const sw = 145;      // breder → meer ruimte voor details
  const depth = 26;    // dieper 3D-effect

  const top = by - stackPixH;

  ctx.save();

  // Schaduw op asfalt (beter contact met grond)
  ctx.shadowColor = '#000';
  ctx.shadowBlur = 30;
  ctx.shadowOffsetY = 18;
  ctx.fillStyle = 'rgba(0,0,0,0.35)';
  ctx.fillRect(cx - sw/2 - 8, by, sw + 16, 18);
  ctx.shadowBlur = 0;
  ctx.shadowOffsetY = 0;

  // 1. Rechter zijvlak (donker, met papier-randen)
  const sideGrad = ctx.createLinearGradient(cx + sw/2, top, cx + sw/2 + depth, by);
  sideGrad.addColorStop(0, '#145a24');
  sideGrad.addColorStop(1, '#0f3f1a');
  ctx.fillStyle = sideGrad;
  ctx.beginPath();
  ctx.moveTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth * 0.45);
  ctx.lineTo(cx + sw/2 + depth, by - depth * 0.45);
  ctx.lineTo(cx + sw/2, by);
  ctx.closePath();
  ctx.fill();

  // Gedetailleerde biljet-randen op zijvlak (papiertextuur)
  ctx.strokeStyle = '#1a7d32';
  ctx.lineWidth = Math.max(0.6, pixPerBill);
  const visibleLayers = Math.min(180, Math.floor(bills / 5) + 20);
  const layerStep = stackPixH / visibleLayers;
  for(let i = 0; i < visibleLayers; i++) {
    const y = top + i * layerStep;
    const sideOffset = (i / visibleLayers) * depth * 0.45;
    ctx.beginPath();
    ctx.moveTo(cx + sw/2, y);
    ctx.lineTo(cx + sw/2 + depth - sideOffset, y - depth * 0.45 + sideOffset * 0.5);
    ctx.stroke();
  }

  // 2. Voorkant (gradient + extreem gedetailleerde papiertextuur)
  const frontGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2, by);
  frontGrad.addColorStop(0, '#22c55e');
  frontGrad.addColorStop(0.25, '#34d46b');
  frontGrad.addColorStop(1, '#16a34a');
  ctx.fillStyle = frontGrad;
  ctx.fillRect(cx - sw/2, top, sw, stackPixH);

  // Honderden horizontale biljet-randen (papiergevoel)
  ctx.strokeStyle = 'rgba(10,50,20,0.65)';
  ctx.lineWidth = 1;
  const numLines = Math.min(220, Math.floor(stackPixH / 1.8));
  const step = stackPixH / numLines;
  for(let i = 0; i < numLines; i++) {
    const y = top + (i * step) + (step / 2);
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 6, y);
    ctx.lineTo(cx + sw/2 - 6, y);
    ctx.stroke();
  }

  // Fijne verticale vezels (extra papier-detail)
  ctx.strokeStyle = 'rgba(255,255,255,0.18)';
  ctx.lineWidth = 0.4;
  for(let i = 0; i < 35; i++) {
    const x = cx - sw/2 + 10 + (i * (sw - 20) / 35);
    ctx.beginPath();
    ctx.moveTo(x, top);
    ctx.lineTo(x + (Math.sin(i) * 4), by);
    ctx.stroke();
  }

  // 💵-symbolen en details op voorkant
  ctx.fillStyle = 'rgba(255,255,255,0.22)';
  ctx.font = `900 ${Math.min(42, stackPixH * 0.22)}px DM Mono`;
  ctx.textAlign = 'center';
  ctx.fillText('💵', cx, top + stackPixH * 0.48);

  if(stackPixH > 80) {
    ctx.font = `700 ${Math.min(22, stackPixH * 0.12)}px DM Mono`;
    ctx.fillText('$', cx - sw*0.32, top + stackPixH * 0.25);
    ctx.fillText('$', cx + sw*0.32, top + stackPixH * 0.75);
  }

  // 3. Bovenkant van de stapel (zeer gedetailleerde bovenste biljet + 3D-perspectief)
  const topGrad = ctx.createLinearGradient(cx - sw/2, top, cx + sw/2 + depth, top - depth*0.45);
  topGrad.addColorStop(0, '#4ade80');
  topGrad.addColorStop(1, '#34c16a');
  ctx.fillStyle = topGrad;
  ctx.beginPath();
  ctx.moveTo(cx - sw/2, top);
  ctx.lineTo(cx + sw/2, top);
  ctx.lineTo(cx + sw/2 + depth, top - depth*0.45);
  ctx.lineTo(cx - sw/2 + depth, top - depth*0.45);
  ctx.closePath();
  ctx.fill();

  // Rand van bovenste biljet
  ctx.strokeStyle = '#0f3f1a';
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.moveTo(cx - sw/2 + 4, top + 2);
  ctx.lineTo(cx + sw/2 - 4, top + 2);
  ctx.lineTo(cx + sw/2 + depth - 4, top - depth*0.45 + 2);
  ctx.lineTo(cx - sw/2 + depth + 4, top - depth*0.45 + 2);
  ctx.closePath();
  ctx.stroke();

  // Gedetailleerd ontwerp op bovenkant (100, $, portret-gebied, security-lijnen)
  ctx.save();
  ctx.fillStyle = '#15803d';
  ctx.fillRect(cx - sw/2 + 12, top + 8, sw - 24, -depth*0.45 + 22);

  ctx.fillStyle = 'rgba(255,255,255,0.35)';
  ctx.font = 'bold 26px DM Sans';
  ctx.fillText('100', cx - 8, top - 12);
  ctx.font = 'bold 36px serif';
  ctx.fillText('$', cx + 12, top - 32);

  // Portret-gebied
  ctx.fillStyle = 'rgba(20,20,20,0.25)';
  ctx.fillRect(cx - 28, top - 48, 56, 32);

  // Security-patroon lijnen
  ctx.strokeStyle = 'rgba(255,255,255,0.4)';
  ctx.lineWidth = 1;
  for(let i = 0; i < 6; i++) {
    ctx.beginPath();
    ctx.moveTo(cx - sw/2 + 20, top - 20 - i*4);
    ctx.lineTo(cx + sw/2 - 20, top - 20 - i*4);
    ctx.stroke();
  }
  ctx.restore();

  // Glow rond de hele stapel
  ctx.shadowColor = '#22c55e';
  ctx.shadowBlur = 22;
  ctx.strokeStyle = 'rgba(34,197,94,0.35)';
  ctx.lineWidth = 3;
  ctx.strokeRect(cx - sw/2, top, sw, stackPixH);

  ctx.restore();
}

// ═══════════════════════════════════════════════════
//  MILESTONE MARKERS
// ═══════════════════════════════════════════════════
function drawMilestoneMarkers(altM) {
  const screenH_in_m = (H * 0.5) * BILL_M;
  for(const ms of MILESTONES) {
    if(ms.m === 0) continue;
    const diff = ms.m - altM;
    const range = screenH_in_m * 3;
    if(Math.abs(diff) > range) continue;

    const maxPixH = H * 0.5;
    const bills = Math.max(totalBills, 1);
    const pixPerBill = bills > maxPixH ? maxPixH / bills : 1;
    const markerY = H * 0.5 - (diff / BILL_M) * Math.min(1, maxPixH / bills);

    if(markerY < 20 || markerY > H - 20) continue;

    ctx.save();
    ctx.globalAlpha = Math.max(0.2, 1 - Math.abs(diff) / range * 0.8);

    ctx.strokeStyle = 'rgba(255,255,255,0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 8]);
    ctx.beginPath();
    ctx.moveTo(0, markerY);
    ctx.lineTo(W, markerY);
    ctx.stroke();
    ctx.setLineDash([]);

    ctx.fillStyle = 'rgba(255,255,255,0.55)';
    ctx.font = '11px DM Sans, sans-serif';
    ctx.fillText(`${ms.emoji} ${ms.label}`, 16, markerY - 5);

    ctx.textAlign = 'right';
    ctx.fillStyle = 'rgba(255,255,255,0.35)';
    ctx.font = '10px DM Mono, monospace';
    ctx.fillText(formatAlt(ms.m), W - 16, markerY - 5);
    ctx.textAlign = 'left';

    ctx.restore();
  }
}

// ═══════════════════════════════════════════════════
//  HUD UPDATES (ongeWijzigd behalve kleine optimalisaties)
// ═══════════════════════════════════════════════════
function formatNum(n) {
  if(n >= 1e12) return (n/1e12).toFixed(2) + 'T';
  if(n >= 1e9)  return (n/1e9).toFixed(2) + 'B';
  if(n >= 1e6)  return (n/1e6).toFixed(2) + 'M';
  if(n >= 1e3)  return (n/1e3).toFixed(1) + 'K';
  return n.toLocaleString('nl-NL');
}

function formatAlt(m) {
  if(m >= 1e12)      return (m/1e12).toFixed(3) + ' Tm';
  if(m >= 1e9)       return (m/1e9).toFixed(3) + ' Gm';
  if(m >= 1e6)       return (m/1e6).toFixed(3) + ' Mm';
  if(m >= 1000)      return (m/1000).toFixed(2) + ' km';
  if(m >= 1)         return m.toFixed(2) + ' m';
  if(m >= 0.01)      return (m*100).toFixed(1) + ' cm';
  return (m*1000).toFixed(2) + ' mm';
}

function updateHUD() {
  const altM = displayBills * BILL_M;
  const altEl = document.getElementById('hud-alt');
  const unitEl = document.getElementById('hud-unit');
  if(altM >= 1000) {
    altEl.textContent = (altM/1000).toFixed(4);
    unitEl.textContent = 'kilometer';
  } else if(altM >= 1) {
    altEl.textContent = altM.toFixed(4);
    unitEl.textContent = 'meter';
  } else if(altM >= 0.01) {
    altEl.textContent = (altM*100).toFixed(2);
    unitEl.textContent = 'centimeter';
  } else {
    altEl.textContent = (altM*1000).toFixed(2);
    unitEl.textContent = 'millimeter';
  }

  let next = null;
  for(const ms of MILESTONES) {
    if(ms.m > altM) { next = ms; break; }
  }
  if(next) {
    const billsNeeded = Math.ceil((next.m - altM) / BILL_M);
    document.getElementById('hud-next').textContent =
      `${next.emoji} ${next.label} — nog ${formatNum(billsNeeded)} klikken`;
  } else {
    document.getElementById('hud-next').textContent = '🌌 Voorbij alle mijlpalen!';
  }

  document.getElementById('bill-number').textContent = formatNum(totalBills);

  for(const ms of MILESTONES) {
    if(ms.m === 0) continue;
    if(altM >= ms.m && !shownMilestones.has(ms.m)) {
      shownMilestones.add(ms.m);
      localStorage.setItem('md2_shown', JSON.stringify([...shownMilestones]));
      showMilestoneBanner(ms);
    }
  }
}

let bannerTimeout = null;
function showMilestoneBanner(ms) {
  const el = document.getElementById('milestone-banner');
  document.getElementById('milestone-emoji').textContent = ms.emoji;
  document.getElementById('milestone-name').textContent = ms.label;
  document.getElementById('milestone-sub').textContent =
    `${formatAlt(ms.m)} hoog — ${formatNum(Math.round(ms.m / BILL_M))} biljetten`;
  el.classList.add('show');
  if(bannerTimeout) clearTimeout(bannerTimeout);
  bannerTimeout = setTimeout(() => el.classList.remove('show'), 3500);
}

function updateScoreboard() {
  scores[myName] = myClicks;
  localStorage.setItem('md2_scores', JSON.stringify(scores));
  const sorted = Object.entries(scores).sort((a,b)=>b[1]-a[1]).slice(0,7);
  const list = document.getElementById('score-list');
  list.innerHTML = '';
  for(const [name, clicks] of sorted) {
    const row = document.createElement('div');
    row.className = 'score-row' + (name === myName ? ' me' : '');
    row.innerHTML = `<span class="score-name">${name}</span><span class="score-val">${formatNum(clicks)}</span>`;
    list.appendChild(row);
  }
}

// ═══════════════════════════════════════════════════
//  CLICK + SHADE
// ═══════════════════════════════════════════════════
function shadeColor(hex, pct) {
  const n = parseInt(hex.slice(1), 16);
  const r = Math.min(255, Math.max(0, (n>>16) + pct));
  const g = Math.min(255, Math.max(0, ((n>>8)&0xff) + pct));
  const b = Math.min(255, Math.max(0, (n&0xff) + pct));
  return `rgb(${r},${g},${b})`;
}

function doClick() {
  totalBills++;
  myClicks++;  
  localStorage.setItem('md2_bills', totalBills);
  localStorage.setItem('md2_myclicks', myClicks);
  targetBills = totalBills;
  updateHUD();
  updateScoreboard();
  spawnFloatBill();
  broadcast({ type: 'click', name: myName, total: totalBills, scores });
}

document.getElementById('click-btn').addEventListener('click', doClick);

function spawnFloatBill() {
  const btn = document.getElementById('click-btn');
  const rect = btn.getBoundingClientRect();
  const el = document.createElement('div');
  el.className = 'float-bill';
  el.textContent = '💵';
  el.style.left = (rect.left + rect.width/2 - 12 + (Math.random()-0.5)*30) + 'px';
  el.style.top  = (rect.top - 5) + 'px';
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 900);
}

// ═══════════════════════════════════════════════════
//  NAME + MULTIPLAYER (ongeWijzigd)
// ═══════════════════════════════════════════════════
const nameInput = document.getElementById('name-input');
nameInput.value = myName;
nameInput.addEventListener('change', () => {
  const v = nameInput.value.trim();
  if(!v) return;
  if(scores[myName]) { scores[v] = (scores[v]||0) + scores[myName]; delete scores[myName]; }
  myName = v;
  localStorage.setItem('md2_name', myName);
  updateScoreboard();
});

let peer = null, connections = [];

function setStatus(msg, color='rgba(255,255,255,0.35)') {
  const el = document.getElementById('mp-status');
  el.textContent = msg; el.style.color = color;
}

function generateCode() {
  const c = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  return Array.from({length:4}, ()=>c[Math.floor(Math.random()*c.length)]).join('');
}

function broadcast(data) {
  for(const conn of connections) if(conn.open) try{conn.send(data);}catch(e){}
}

function handleData(peerId, data) {
  if(data.type==='click'||data.type==='sync') {
    if(data.total > totalBills) {
      totalBills = data.total;
      targetBills = totalBills;
      localStorage.setItem('md2_bills', totalBills);
    }
    if(data.scores) {
      for(const [n,c] of Object.entries(data.scores))
        if(n!==myName) scores[n] = Math.max(scores[n]||0, c);
    }
    updateHUD(); updateScoreboard();
  }
}

function setupConn(conn) {
  connections.push(conn);
  conn.on('data', d => handleData(conn.peer, d));
  conn.on('open', () => {
    setStatus(`${connections.length} verbonden`, '#22c55e');
    conn.send({ type:'sync', total:totalBills, scores });
  });
  conn.on('close', () => {
    connections = connections.filter(c=>c!==conn);
    delete scores[conn.peer];
    setStatus(connections.length ? `${connections.length} verbonden` : 'offline',
              connections.length ? '#22c55e' : 'rgba(255,255,255,0.35)');
  });
  conn.on('error', () => {
    connections = connections.filter(c=>c!==conn);
    setStatus(connections.length ? `${connections.length} verbonden` : 'offline',
              connections.length ? '#22c55e' : 'rgba(255,255,255,0.35)');
  });
}

document.getElementById('btn-host').addEventListener('click', () => {
  if(!window.Peer){setStatus('laden...','#fa0');return;}
  if(peer){peer.destroy();peer=null;connections=[];}
  const code = generateCode();
  peer = new Peer(code);
  peer.on('open', id => { setStatus(`code: ${id}`,'#6af'); try{navigator.clipboard.writeText(id);}catch(e){} });
  peer.on('connection', conn => setupConn(conn));
  peer.on('error', e => setStatus('fout: '+e.type,'#f66'));
});

const codeIn = document.getElementById('code-input');
const btnOK  = document.getElementById('btn-join-confirm');
document.getElementById('btn-join').addEventListener('click', () => {
  codeIn.style.display='inline-block'; btnOK.style.display='inline-block'; codeIn.focus();
});
btnOK.addEventListener('click', doJoin);
codeIn.addEventListener('keydown', e => { if(e.key==='Enter') doJoin(); });

function doJoin() {
  const code = codeIn.value.trim().toUpperCase();
  if(!code) return;
  codeIn.style.display='none'; btnOK.style.display='none';
  if(!window.Peer){setStatus('laden...','#fa0');return;}
  if(peer){peer.destroy();peer=null;connections=[];}
  peer = new Peer();
  peer.on('open', () => {
    setStatus('verbinden...','#fa0');
    setupConn(peer.connect(code));
  });
  peer.on('error', e => setStatus('fout: '+e.type,'#f66'));
}

// ═══════════════════════════════════════════════════
//  GAME LOOP
// ═══════════════════════════════════════════════════
function loop() {
  requestAnimationFrame(loop);

  displayBills += (targetBills - displayBills) * 0.08;
  cloudT += 0.0003;

  const altM = displayBills * BILL_M;
  const [r,g,b] = getSkyColor(altM);

  const skyGrad = ctx.createLinearGradient(0, 0, 0, H);
  const darkFactor = Math.max(0, 1 - altM / 50000);
  skyGrad.addColorStop(0, `rgb(${Math.round(r*0.6)},${Math.round(g*0.6)},${Math.round(b*0.6)})`);
  skyGrad.addColorStop(1, `rgb(${r},${g},${b})`);
  ctx.fillStyle = skyGrad;
  ctx.fillRect(0, 0, W, H);

  drawGround(altM);
  drawBuildings(altM);
  drawClouds(altM);
  drawEverest(altM);
  drawJetstream(altM);
  drawSpaceEdge(altM);
  drawISS(altM);

  drawMilestoneMarkers(altM);

  drawMoneyStack(displayBills);   // ← nu extreem gedetailleerd 3D

  updateHUD();
}

// Init
updateHUD();
updateScoreboard();
loop();
