  { m: 46,          label: 'Scheve Toren van Pisa',   emoji: '🗼', sky: [115, 185, 220] },
  { m: 96,          label: 'Grote Piramide van Gizeh',emoji: '🔺', sky: [105, 175, 215] },
  { m: 169,         label: 'Washington Monument',     emoji: '🏛️', sky: [100, 170, 210] },
