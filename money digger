    ctx.fillStyle = '#166534';
    ctx.fillRect(W*0.18, gy - 140, 38, 140);
    ctx.fillStyle = '#4ade80';
    ctx.beginPath(); ctx.arc(W*0.19, gy - 165, 58, 0, Math.PI*2); ctx.fill();
