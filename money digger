    setTimeout(() => fb.remove(), 900);
});

function loop() {
    requestAnimationFrame(loop);
    
    // Sky
    const alt = displayBills * BILL_M;
    const darkness = Math.max(0, 1 - alt / 50000);
    ctx.fillStyle = `rgb(${Math.floor(20 + 80*darkness)}, ${Math.floor(40 + 120*darkness)}, ${Math.floor(80 + 140*darkness)})`;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    drawMoneyStack(displayBills);
    
    // Update counter
    document.getElementById('bill-number').textContent = totalBills.toLocaleString('nl-NL');
}
loop();
</script>
